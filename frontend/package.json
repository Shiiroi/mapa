{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:docker": "vite --mode docker",
        "build": "tsc -b && vite build",
        "seed:stats": "tsx --env-file=.env scripts/seed-stats.ts",
        "scrape:comelec": "scripts/py/.venv/bin/python scripts/py/scrape_comelec.py --base-dir scripts/py/data",
        "map:comelec": "tsx scripts/map-comelec-president.ts",
        "seed:custom-elections": "tsx --env-file=.env scripts/seed-custom-elections.ts",
        "seed:afr": "tsx --env-file=.env scripts/seed-afr-assets.ts",
        "seed:extrapop": "tsx --env-file=.env scripts/seed-extra-pop.ts",
        "seed:gdp": "tsx --env-file=.env scripts/seed-gdp.ts",
        "seed:db": "tsx --env-file=.env scripts/seed-db.ts",
        "seed:bgy": "tsx --env-file=.env scripts/seed-bgy.ts",
        "upload:geo": "tsx --env-file=.env scripts/upload-geo.ts",
        "seed:all": "npm run upload:geo && npm run seed:db && npm run seed:bgy && npm run seed:stats && npm run seed:extrapop && npm run seed:gdp && npm run seed:afr && npm run seed:custom-elections",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.106.2",
        "@tanstack/react-query": "^5.100.14",
        "@turf/area": "^7.3.5",
        "@types/geojson": "^7946.0.16",
        "clsx": "^2.1.1",
        "csv-parse": "^6.2.1",
        "csv-stringify": "^6.7.0",
        "fast-csv": "^5.0.7",
        "h3-js": "^4.4.0",
        "leaflet": "^1.9.4",
        "pg": "^8.21.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-leaflet": "^5.0.0",
        "react-router-dom": "^7.15.1",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.3.1",
        "@types/leaflet": "^1.9.21",
        "@types/node": "^24.12.3",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "tailwindcss": "^4.3.1",
        "tsx": "^4.22.4",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.12"
    }
}
